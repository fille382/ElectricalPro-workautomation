[
  {
    "name": "jobs",
    "type": "base",
    "schema": [
      { "name": "name", "type": "text", "required": true },
      { "name": "address", "type": "text" },
      { "name": "description", "type": "text" },
      { "name": "contacts", "type": "json" },
      { "name": "lat", "type": "number" },
      { "name": "lon", "type": "number" },
      { "name": "status", "type": "text", "required": true },
      { "name": "owner", "type": "relation", "options": { "collectionId": "_pb_users_auth_", "maxSelect": 1 } }
    ],
    "listRule": "owner = @request.auth.id || @request.auth.id ?= @collection.job_shares.user.id",
    "viewRule": "owner = @request.auth.id || @request.auth.id ?= @collection.job_shares.user.id",
    "createRule": "@request.auth.id != ''",
    "updateRule": "owner = @request.auth.id",
    "deleteRule": "owner = @request.auth.id"
  },
  {
    "name": "tasks",
    "type": "base",
    "schema": [
      { "name": "job", "type": "relation", "required": true, "options": { "collectionId": "jobs", "maxSelect": 1, "cascadeDelete": true } },
      { "name": "title", "type": "text", "required": true },
      { "name": "description", "type": "text" },
      { "name": "status", "type": "text", "required": true },
      { "name": "notes", "type": "text" },
